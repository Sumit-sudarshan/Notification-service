
# Instructions:
# 1. Copy this file to '.env':
#    cp .env.example .env
# 2. Update the variables below as needed for your environment.

# ------------------------------------------------------------
# Application Settings
# ------------------------------------------------------------
APP_ENV=development          # Environment mode (development, production, staging)
LOG_LEVEL=INFO               # Log severity level (DEBUG, INFO, WARNING, ERROR)

# ------------------------------------------------------------
# Security & Authentication
# ------------------------------------------------------------
# The API key required in the 'X-API-Key' HTTP header for client authentication.
# For local testing, keep the default. For production, generate a secure random key:
API_KEY=super-secret-api-key

# ------------------------------------------------------------
# Database Configuration (PostgreSQL)
# ------------------------------------------------------------
# Format: postgresql+asyncpg://<username>:<password>@<host>:<port>/<database_name>
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/notification_service

# ------------------------------------------------------------
# Cache & Message Queue Configuration (Redis)
# ------------------------------------------------------------
# Format: redis://<host>:<port>/<database_index>
REDIS_URL=redis://localhost:6379/0

# ------------------------------------------------------------
# Rate Limiting (Sliding Window via Redis)
# ------------------------------------------------------------
# Rate limit applied per user_id across the API.
RATE_LIMIT_REQUESTS=100      # Maximum number of requests allowed in the window
RATE_LIMIT_WINDOW_SECONDS=3600  # Window duration in seconds (3600 = 1 hour)

# ------------------------------------------------------------
# Idempotency
# ------------------------------------------------------------
# How long idempotency response payloads are cached before expiration.
IDEMPOTENCY_TTL_HOURS=24

# ------------------------------------------------------------
# Worker Configuration
# ------------------------------------------------------------
# The number of concurrent tasks the background worker processes simultaneously.
WORKER_CONCURRENCY=4

# ------------------------------------------------------------
# Retry & Exponential Backoff Settings
# ------------------------------------------------------------
# If a notification delivery fails, it is retried with an exponential delay:
#   delay = RETRY_BASE_DELAY_SECONDS * (RETRY_MULTIPLIER ^ retry_count)
# Default values result in: Retry 1 = 30s, Retry 2 = 120s (2m), Retry 3 = 480s (8m)
MAX_RETRIES=3
RETRY_BASE_DELAY_SECONDS=30
RETRY_MULTIPLIER=4

# ------------------------------------------------------------
# Mock External Service Providers
# ------------------------------------------------------------
# Simulated failure rate for mock Email, SMS, and Push providers (0.0 to 1.0).
#   0.0 = Calls always succeed (useful for clean testing/demos)
#   0.1 = ~10% of calls fail randomly (useful for testing retries and circuit breakers)
PROVIDER_FAILURE_RATE=0.1
